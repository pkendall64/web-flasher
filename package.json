{
  "name": "flasher2",
  "private": true,
  "version": "2.0.0",
  "license": "GPL-3.0-only",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "vite",
    "build": "npm run build:packages && vite build",
    "build:packages": "npm run build -w elrs-flasher && npm run build -w elrs-firmware-config",
    "typecheck": "npm run build:packages && vue-tsc -p tsconfig.app.json --noEmit",
    "preview": "vite preview"
  },
  "dependencies": {
    "crypto-js": "^4.2.0",
    "elrs-firmware-config": "file:packages/elrs-firmware-config",
    "elrs-flasher": "file:packages/elrs-flasher",
    "@mdi/font": "7.4.47",
    "@zip.js/zip.js": "^2.8.22",
    "bluejay-rtttl-parse": "^2.0.2",
    "file-saver": "^2.0.5",
    "pako": "^2.1.0",
    "roboto-fontface": "*",
    "vue": "^3.5.29",
    "vue-localstorage": "^0.6.2",
    "vuetify": "^4.0.0"
  },
  "devDependencies": {
    "@types/file-saver": "^2.0.7",
    "@types/pako": "^2.0.4",
    "@types/crypto-js": "^4.2.2",
    "@types/w3c-web-serial": "^1.0.8",
    "@types/w3c-web-usb": "^1.0.10",
    "typescript": "^5.6.0",
    "vue-tsc": "^2.2.0",
    "@vitejs/plugin-vue": "^6.0.4",
    "sass": "1.97.3",
    "unplugin-fonts": "^1.4.0",
    "unplugin-vue-components": "^31.0.0",
    "vite-plugin-pwa": "^1.2.0",
    "vite-plugin-vuetify": "^2.1.3"
  }
}
